{
  "name": "stopcock-monorepo",
  "private": true,
  "type": "module",
  "description": "High-performance functional programming library for TypeScript",
  "license": "MIT",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "docs:dev": "turbo run dev --filter=@stopcock/docs",
    "docs:build": "turbo run build --filter=@stopcock/docs",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset"
  },
  "packageManager": "bun@1.3.11",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@fast-check/vitest": "0.3",
    "@rescript/language-server": "^1.72.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260403.1",
    "@vitest/coverage-v8": "^4.0.0",
    "fast-check": "^3.23.0",
    "tsup": "^8.5.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
